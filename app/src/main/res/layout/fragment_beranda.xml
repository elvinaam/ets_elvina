<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mist_blue"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Welcome -->
    <TextView
        android:id="@+id/tvWelcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Halo, Innovators!"
        android:textColor="@color/navy_main"
        android:textSize="24sp"
        android:fontFamily="@font/plus_jakarta_sans_bold" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Temukan tantangan industri hari ini"
        android:textColor="@color/near_black"
        android:textSize="14sp"
        android:fontFamily="@font/poppins_regular"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="16dp" />

    <!-- Search -->
    <androidx.appcompat.widget.SearchView
        android:id="@+id/searchChallenge"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_search_white"
        android:layout_marginBottom="12dp"
        app:queryHint="Cari kategori (IT, Lingkungan...)"
        app:iconifiedByDefault="false" />

    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChallenge"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

</LinearLayout>